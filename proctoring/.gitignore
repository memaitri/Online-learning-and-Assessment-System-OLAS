# ── Python cache ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────
.venv/
venv/
env/

# ── ML model files (large binaries — download separately) ────────────
*.pt          # YOLO weights  (yolov8n.pt, yolov8s.pt, custom.pt …)
*.tflite      # MediaPipe models (blaze_face_short_range.tflite …)
*.task        # MediaPipe task bundles (face_landmarker.task …)

# ── Logs and generated reports ────────────────────────────────────────
logs/
*.log
session_output.json

# ── OS / editor artefacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
