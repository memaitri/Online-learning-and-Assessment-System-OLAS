generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("student")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdClasses      Class[]              @relation("CreatedClasses")
  facultyClasses      Class[]              @relation("FacultyClasses")
  studentClasses      Class[]              @relation("StudentClasses")
  createdExams        Exam[]               @relation("CreatedExams")
  examSessions        StudentExamSession[]
  submissions         Submission[]
  violations          Violation[]
  gradedSubmissions   Submission[]         @relation("GradedSubmissions")
}

model Class {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facultyId String
  faculty   User   @relation("FacultyClasses", fields: [facultyId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedClasses", fields: [createdById], references: [id], onDelete: Cascade)

  students User[] @relation("StudentClasses")
  exams    Exam[]
}

model Exam {
  id               String   @id @default(uuid())
  title            String
  description      String?
  startTime        DateTime
  endTime          DateTime
  duration         Int
  allowedLanguages Json
  maxViolations    Int      @default(3)
  questions        Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedExams", fields: [createdById], references: [id], onDelete: Cascade)

  sessions    StudentExamSession[]
  submissions Submission[]
  violations  Violation[]
}

model StudentExamSession {
  id          String    @id @default(uuid())
  status      String    @default("in_progress")
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Module 7: AI Proctoring risk fields ──────────────────────────────
  riskScore            Float?   // 0–100 cumulative risk score
  riskLevel            String?  // SAFE | LOW | MEDIUM | HIGH | CRITICAL
  totalViolations      Int?     // total AI-detected violation events
  proctoringReportPath String?  // path to session_report.txt on disk

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  violations Violation[]

  @@unique([studentId, examId])
}

model Submission {
  id          String    @id @default(uuid())
  code        String
  language    String
  output      String?
  score       Float?
  feedback    String?
  question    Int
  submittedAt DateTime  @default(now())
  gradedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  gradedById String?
  gradedBy   User?   @relation("GradedSubmissions", fields: [gradedById], references: [id])
}

model Violation {
  id          String   @id @default(uuid())
  type        String
  description String
  severity    String   @default("medium")
  timestamp   DateTime @default(now())

  sessionId String
  session   StudentExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
}
